{
  "name": "composer-layout-root",
  "private": true,
  "version": "0.0.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "dev": "npm run dev --workspace quiz-app-example",
    "dev:quiz": "npm run dev --workspace quiz-app-example",
    "dev:assistant": "npm run dev --workspace ai-assistant-example"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vitest": "^4.0.14"
  }
}
